# ─────────────────────────────────────────────────────────────
# HOPECMS — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` in the repo root, then paste the
# real values from the pinned message in our team GC.
#
# NEVER commit your actual `.env` file to git.
# ─────────────────────────────────────────────────────────────

# Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon / public key (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=your_anon_key_here
